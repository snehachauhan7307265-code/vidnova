{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the application.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "subscribers": { "type": "number" },
        "verified": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "displayName", "email", "createdAt"]
    },
    "Video": {
      "title": "Video",
      "description": "A video uploaded by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "userId": { "type": "string" },
        "views": { "type": "number" },
        "duration": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "title", "videoUrl", "userId", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a video.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "videoId": { "type": "string" },
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "videoId", "userId", "text", "createdAt"]
    },
    "Like": {
      "title": "Like",
      "description": "A like on a video.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "videoId": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "videoId", "userId", "createdAt"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "A user subscribing to another user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "subscriberId": { "type": "string" },
        "channelId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "subscriberId", "channelId", "createdAt"]
    },
    "Playlist": {
      "title": "Playlist",
      "description": "A playlist of videos.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "videoIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "title", "createdAt"]
    },
    "WatchHistory": {
      "title": "WatchHistory",
      "description": "A record of a video watched by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "videoId": { "type": "string" },
        "watchedAt": { "type": "string" }
      },
      "required": ["id", "userId", "videoId", "watchedAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "type", "message", "read", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    },
    "/videos/{videoId}": {
      "schema": { "$ref": "#/entities/Video" },
      "description": "Uploaded videos."
    },
    "/videos/{videoId}/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Comments on a video."
    },
    "/likes/{likeId}": {
      "schema": { "$ref": "#/entities/Like" },
      "description": "Likes on videos."
    },
    "/subscriptions/{subscriptionId}": {
      "schema": { "$ref": "#/entities/Subscription" },
      "description": "User subscriptions to channels."
    },
    "/playlists/{playlistId}": {
      "schema": { "$ref": "#/entities/Playlist" },
      "description": "User playlists."
    },
    "/users/{userId}/watchHistory/{historyId}": {
      "schema": { "$ref": "#/entities/WatchHistory" },
      "description": "User watch history."
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "User notifications."
    }
  }
}
